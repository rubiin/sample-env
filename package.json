{
  "name": "sample-env",
  "version": "2.1.4",
  "description": "Generate sample file from .env for your apps",
  "keywords": [
    "cli",
    "dotenv",
    "env",
    "sample"
  ],
  "homepage": "https://github.com/rubiin/sample-env#readme",
  "bugs": {
    "url": "https://github.com/rubiin/sample-env/issues"
  },
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/sample-env.git"
  },
  "funding": "https://github.com/sponsors/rubiin",
  "bin": {
    "sample-env": "./bin/sample-env.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "npm run build",
    "release": "bumpp && pnpm publish",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^2.2.0",
    "@types/node": "^24.12.3",
    "@types/yargs": "^17.0.35",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
