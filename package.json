{
  "name": "sample-env",
  "version": "2.1.4",
  "description": "Generate sample file from .env for your apps",
  "keywords": [
    "cli",
    "dotenv",
    "env",
    "sample"
  ],
  "homepage": "https://github.com/rubiin/sample-env#readme",
  "bugs": {
    "url": "https://github.com/rubiin/sample-env/issues"
  },
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/sample-env.git"
  },
  "funding": "https://github.com/sponsors/rubiin",
  "bin": {
    "sample-env": "./bin/sample-env.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxlint",
    "prepublishOnly": "npm run build",
    "release": "bumpp && pnpm publish",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^1.2.1",
    "@types/node": "^24.12.2",
    "@types/yargs": "^17.0.35",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "readmeFilename": "README.md"
}
